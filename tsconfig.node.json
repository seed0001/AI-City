{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "strict": true,
    "noEmit": true
  },
  "include": ["vite.config.ts", "vite-plugin-edge-tts.ts", "vite-plugin-lan-hub.ts"]
}
